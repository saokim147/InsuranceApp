@model DeleteViewModel
<div class="pointer-events-auto flex flex-col rounded-xl border bg-white shadow-sm">
	<div class="p-6 text-center">
		<svg aria-hidden="true" class="mx-auto mb-4 size-5 text-gray-400" fill="none"
			 stroke="currentColor" viewBox="0 0 24 24"
			 xmlns="http://www.w3.org/2000/svg">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
				  d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
			</path>
		</svg>
		<h3 class="mb-5 text-lg font-normal text-gray-500">Bạn có muốn xóa ?</h3>
		<button type="button" class="btn btn-primary"
				hx-post="@Url.Action("Delete","Hospital")"
				hx-vals='{"id":"@(Model.Id)"}' hx-target="#hospital-table">
			Có
		</button>
		<button type="button" class="btn btn-outline-primary" id="close-delete-btn">
			Không
		</button>
	</div>
</div>
<script>
	document.getElementById('close-delete-btn').addEventListener('click', () => {
		HSOverlay.close('#addFormContainer');
	})
</script>